# ── Agent build requirements ──────────────────────────────────────────────────
# Tokens are NOT required if you are already logged in via CLI:
#   vercel login   — authenticates the Vercel CLI
#   gh auth login  — authenticates the GitHub CLI
#
# GH_REPO is auto-detected from the git remote and does not need to be set.
#
# Only set these if you prefer token-based auth over CLI sessions:

# VERCEL_TOKEN=     # https://vercel.com/account/tokens
# GITHUB_TOKEN=     # https://github.com/settings/tokens (repo scope)
# GH_REPO=shorn-gnosis/circles-miniapps-for-agents
