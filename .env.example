# ── Agent build requirements ──────────────────────────────────────────────────
# Copy this file to .env and fill in your values before running the agent.
# Never commit .env — it is gitignored.

# Vercel personal access token — https://vercel.com/account/tokens
VERCEL_TOKEN=

# GitHub token with repo write scope — https://github.com/settings/tokens
# Required for opening PRs via the gh CLI.
# If `gh auth login` is already set up on your machine, this is optional.
GITHUB_TOKEN=

# Target GitHub repo for PRs (owner/repo)
GH_REPO=shorn-gnosis/circles-miniapps-for-agents
